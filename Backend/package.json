{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "advanced-voting-backend",
  "version": "1.0.0",
  "description": "Backend API for Advanced Blockchain Voting Platform",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "db:init": "ts-node src/scripts/database.ts init",
    "db:init:seeds": "ts-node src/scripts/database.ts init --seeds",
    "db:migrate": "ts-node src/scripts/database.ts migrate",
    "db:rollback": "ts-node src/scripts/database.ts rollback",
    "db:seed": "ts-node src/scripts/database.ts seed",
    "db:status": "ts-node src/scripts/database.ts status",
    "db:reset": "ts-node src/scripts/database.ts reset --confirm",
    "db:cleanup": "ts-node src/scripts/database.ts cleanup",
    "db:health": "ts-node src/scripts/database.ts health",
    "db:stats": "ts-node src/scripts/database.ts stats",
    "otp:latest": "node scripts/get-latest-otp.js",
    "votes:latest": "node scripts/show-latest-votes.js",
    "demo:create-active-election": "node scripts/create-active-election.js",
    "user:bootstrap": "node scripts/bootstrap-user.js",
    "demo:reset-seed": "node scripts/reset-seed-demo-data.js"
  },
  "keywords": [
    "blockchain",
    "voting",
    "express",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.12.2",
    "bcryptjs": "^2.4.3",
    "commander": "^11.1.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "ethers": "^6.8.0",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "nodemailer": "^6.10.1",
    "pg": "^8.11.3",
    "rate-limiter-flexible": "^4.0.1",
    "redis": "^4.6.10",
    "winston": "^3.11.0",
    "ws": "^8.14.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/morgan": "^1.9.9",
    "@types/nodemailer": "^6.4.17",
    "@types/node": "^20.8.10",
    "@types/pg": "^8.10.7",
    "@types/supertest": "^2.0.16",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^6.9.1",
    "@typescript-eslint/parser": "^6.9.1",
    "eslint": "^8.53.0",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.2.2"
  }
}
